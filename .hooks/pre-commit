#!/bin/bash
# Pre-commit hook for quality checks

set -e

echo "🔍 Running pre-commit checks..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ERRORS=0

run_check() {
    if eval "$1"; then
        echo -e "${GREEN}✓ $2${NC}"
        return 0
    else
        echo -e "${RED}✗ $2${NC}"
        ((ERRORS++))
        return 1
    fi
}

# Linting
if [ -f "package.json" ] && grep -q "\"lint\"" package.json; then
    echo ""
    echo "🎨 Linting:"
    run_check "npm run lint --silent" "ESLint check" || true
fi

# TypeScript check
if [ -f "tsconfig.json" ]; then
    echo ""
    echo "📘 TypeScript:"
    run_check "npx tsc --noEmit" "TypeScript check" || true
fi

# Security check
if command -v gitleaks &> /dev/null && [ -f ".gitleaks.toml" ]; then
    echo ""
    echo "🔒 Security:"
    run_check "gitleaks detect --no-git --config .gitleaks.toml --no-banner" "Secret detection" || true
fi

# Check for large files
echo ""
echo "📏 File Size Check:"
LARGE_FILES=$(find . -type f -size +2M -not -path "./node_modules/*" -not -path "./.git/*" -not -path "./dist/*" 2>/dev/null || true)
if [ -n "$LARGE_FILES" ]; then
    echo -e "${YELLOW}⚠ Warning: Large files found:${NC}"
    echo "$LARGE_FILES"
fi

# Check for secrets in staged files
echo ""
echo "🔐 Secret Check:"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v "package-lock.json" | grep -v "yarn.lock" || true)
if [ -n "$STAGED_FILES" ]; then
    SECRETS=$(echo "$STAGED_FILES" | xargs grep -l "password\|secret\|api_key\|token\|credential" 2>/dev/null || true)
    if [ -n "$SECRETS" ]; then
        echo -e "${YELLOW}⚠ Files with sensitive keywords:${NC}"
        echo "$SECRETS"
        echo "Please verify no real secrets are being committed."
    fi
fi

# Summary
echo ""
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}✗ $ERRORS check(s) failed${NC}"
    echo ""
    echo "Please fix errors or bypass with: git commit --no-verify"
    exit 1
else
    echo -e "${GREEN}✓ All checks passed!${NC}"
fi
